# Optional server-side fallbacks. Everything can also be provided from the
# in-app Settings panel and is persisted in browser localStorage.
#
# Glean (MCP over HTTPS) — personal API token from
# https://mongodb-be.glean.com/settings/developer (requires MCP scopes).
GLEAN_MCP_URL=https://mongodb-be.glean.com/mcp/default
GLEAN_API_TOKEN=

# Monday MCP (optional — runs locally from the parent premserv repo).
MONDAY_MCP_URL=http://localhost:3001/mcp

# LLM provider for risk-register synthesis and case analysis.
# Set credentials for the provider you select.
LLM_PROVIDER=mongogpt         # "mongogpt" | "openai" | "anthropic"

# MongoGPT (internal — Kanopy OIDC auth).
#
# First time you open the app it will:
#   1. Download kanopy-oidc into ~/kanopy/bin/  (via `gh` CLI by default;
#      falls back to GITHUB_TOKEN, then KANOPY_OIDC_DOWNLOAD_URL).
#   2. Write ~/.kanopy/config.yaml if missing.
#   3. Run `kanopy-oidc login` which opens a browser for SSO.
#   4. Cache the JWT in ~/.kanopy/risksi-token.json until its exp claim passes.
#
# You only need to populate MONGOGPT_URL unless you're overriding the default
# endpoint. Leave MONGOGPT_TOKEN / MONGOGPT_MODEL blank and pick a model from
# the dropdown in Settings after the first login.
# PremServ-style base URL (no path); app resolves …/api/v1/messages
MONGOGPT_URL=https://mongogpt.aix.prod.corp.mongodb.com
MONGOGPT_MODEL=
MONGOGPT_TOKEN=

# Optional: auth for downloading the private kanopy-oidc release. Pick ONE.
#   - `gh auth login` — no env var needed (recommended on corp Macs).
#   - GITHUB_TOKEN — personal access token with access to the repo.
#   - KANOPY_OIDC_DOWNLOAD_URL — direct URL to a tarball mirror.
# GITHUB_TOKEN=
# KANOPY_OIDC_DOWNLOAD_URL=
# KANOPY_OIDC_REPO=kanopy-platform/kanopy-oidc

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
